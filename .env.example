# ============================================================================
#  VétoAI — Variables d'environnement (.env.example)
#  Copie ce fichier en .env, ajuste, **ne commit jamais le .env réel**.
# ============================================================================

# ----- Base de données -----
DATABASE_URL=postgresql://user:password@host:5432/vetoai

# ----- Clerk auth -----
CLERK_SECRET_KEY=sk_test_xxxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
# optionnel — base URL du dashboard si tu utilises un domaine custom
# CLERK_PROXY_URL=https://app.vetoai.fr/__clerk

# ----- Anthropic (IA) -----
ANTHROPIC_API_KEY=sk-ant-xxxx

# ----- HTTP -----
PORT=3000
APP_URL=https://app.vetoai.fr
SESSION_SECRET=un-secret-long-aleatoire-32-bytes-minimum

# ----- CORS — P0-2 -----
# Liste d'origines autorisées séparées par virgule.
# En dev local : "http://localhost:5173,http://localhost:3000"
CORS_ALLOWED_ORIGINS=https://app.vetoai.fr

# ----- Object Storage — P0-4 -----
# "gcs" (production Railway / GCP) ou "replit-sidecar" (dev sur Replit).
OBJECT_STORAGE_PROVIDER=gcs
# Service account JSON encodé en base64 (seulement si PROVIDER=gcs et pas de ADC).
# Commande : base64 -w 0 service-account.json
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Legacy Replit — utilisés uniquement en mode replit-sidecar
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=/my-bucket/.private
PUBLIC_OBJECT_SEARCH_PATHS=/my-bucket/public

# ----- Email transactionnel -----
RESEND_API_KEY=re_xxxx
RESEND_FROM="VétoAI <no-reply@vetoai.fr>"

# ----- Portail client — P0-1 -----
# TTL des liens portail propriétaire (en jours). Défaut : 90.
PORTAIL_TOKEN_TTL_DAYS=90

# ----- Observabilité backend -----
# DSN Sentry côté API (différent de celui du front).
SENTRY_DSN=
# Release Sentry — en CI : $GITHUB_SHA, en local : laisser vide → "dev"
SENTRY_RELEASE=
NODE_ENV=production

# ----- Observabilité frontend (Vite, exposé au browser) -----
# DSN Sentry côté front. Peut être le même projet ou séparé.
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=

# ----- AI tokens (P2-3) -----
# Surcharges optionnelles des max_tokens Anthropic par défaut.
# AI_MAX_TOKENS_LONG=8192
# AI_MAX_TOKENS_SHORT=2048

# ----- Rate-limit IA (P2-7) -----
# Limite le nombre d'appels IA par minute et par clinique pour protéger le budget
# Anthropic. Défaut : 20 req/min.
AI_RATE_LIMIT_PER_MIN=20

# ----- Body JSON limits (P2-5) -----
# Limite par défaut sur le body JSON (1mb). Les routes d'upload base64
# peuvent avoir leur propre limite de 10mb localement.
JSON_BODY_LIMIT=1mb

# ----- Tests -----
# URL de la DB de test pour les tests e2e backend (supertest).
# Laisser vide ou non défini pour skipper les tests e2e en local.
TEST_DATABASE_URL=
