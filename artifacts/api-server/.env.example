# ─── VétoAI — Variables d'environnement requises ─────────────────────────────
# Copier ce fichier en .env et renseigner toutes les valeurs avant démarrage.
# Le serveur refuse de démarrer si une variable obligatoire (*) est manquante.

# ─── Base de données (Railway PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@hostname:5432/dbname          # *

# ─── Clerk Authentication ────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...                                           # *
CLERK_PUBLISHABLE_KEY=pk_live_...                                      # * (frontend)
CLERK_WEBHOOK_SECRET=whsec_...                                         # * (webhooks)

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                                                  # *

# ─── Twilio SMS ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...                                               # optionnel (SMS désactivé si absent)
TWILIO_AUTH_TOKEN=...                                                  # optionnel
TWILIO_PHONE_NUMBER=+33...                                             # optionnel

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production                                                    # production | development
PORT=3000

# ─── Frontend URL (CORS whitelist) ───────────────────────────────────────────
FRONTEND_URL=https://app.vetoai.fr                                     # * (pas de trailing slash)

# ─── Railway injectées automatiquement (ne pas modifier) ─────────────────────
# RAILWAY_ENVIRONMENT=production
# RAILWAY_SERVICE_ID=...
